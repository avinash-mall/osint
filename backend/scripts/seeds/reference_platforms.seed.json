  "version": "2026-05-27-plan-b",
  "description": "Reference platform seed manifest. Curated bridge between source-dataset class names and canonical platform identities. DOTA proof-of-life: one row per DOTA class with the class name as platform_family. Later seeds (xView, RarePlanes) will add real platforms (F-35, B-2, etc.) and deepen the `attributes` field. The bake script (backend/scripts/bake_reference_db.py, Task 6) reads this file and uses `source_terms_per_dataset.<dataset>` to locate chip directories.",
  "field_notes": {
    "platform_name": "Globally unique identifier. DOTA placeholders use the `DOTA::<class>` prefix to keep them clearly distinguishable from real-world platforms added later.",
    "platform_family": "CamelCase grouping. For DOTA placeholders this mirrors the class name; for real platforms it groups variants (e.g. F-35A/B/C share family `F-35`).",
    "ontology_object_id": "Optional FK to ontology_objects.id. Nullable; ON DELETE SET NULL. Left null when no sensible ontology match exists (e.g. sports facilities).",
    "country_of_origin": "ISO-style or short country code. Null for DOTA placeholders (generic class, no specific platform).",
    "role": "Short human-readable description shown in admin UI.",
    "attributes": "Free-form JSON object for platform-specific metadata (length_m, crew, etc.). Empty for DOTA placeholders; populated by later xView / RarePlanes seeds.",
    "source_terms_per_dataset": "Map of dataset name -> list of class/term strings. The baker uses this to find chip directories under each dataset's chip root. For DOTA the value matches the chip-directory class name exactly."
  },
