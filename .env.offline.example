# =====================================================================
# Air-gap deployment overrides
# ---------------------------------------------------------------------
# Copy this file to `.env` on the air-gapped host BEFORE `docker compose up`.
# Use the ordinary `.env.example` on the connected build host so weights
# can be fetched once during `docker compose build`.
# =====================================================================

# Disable LLM-backed features (ontology auto-update, free-form prompt
# fan-out etc.). The platform degrades gracefully — UI keeps working;
# anything that needed a chat model logs `AIUnavailable` and skips.
OPENAI_API_BASE=

# Already the new default in docker-compose.yml, but pinned here so
# operators can audit at a glance. Setting these to 1 forces transformers
# and huggingface_hub to refuse any network call — they will fail loudly
# if a path inside the model code tries to fetch something that wasn't
# baked into the image.
SAM3_HF_HUB_OFFLINE=1
SAM3_TRANSFORMERS_OFFLINE=1

# Build-time only. Leave EMPTY on the offline host — the image already
# carries every weight under /models/hf. On the connected build host this
# must be set to a Hugging Face token with access to facebook/sam3 and
# facebook/dinov3-* (both gated).
HF_TOKEN=

# Required by docker-compose interpolation; values come from the
# connected-host `scripts/configure_host.py` run. Copy them verbatim into
# this file before bringing up the stack on the offline server.
# SAM3_CUDA_VERSION=12.6.3
# SAM3_UBUNTU_VERSION=24.04
# SAM3_TORCH_INDEX_URL=https://download.pytorch.org/whl/cu126
# SAM3_TORCH_VERSION=2.7.1
# SAM3_TORCHVISION_VERSION=0.22.1
# SAM3_TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0;12.0+PTX
# GPU_MODEL=...
# SAM3_GPU_PROFILE=...
