# Sentinel environment template.
# Copy values into .env and replace placeholder secrets before running.
# Never commit real tokens or generated secrets.
# --- Core services ---------------------------------------------------------

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
# Required (fail-closed, like ADMIN_PASSWORD). Use a long random value. Applied to
# the neo4j_data volume on FIRST boot only — rotate later with `cypher-shell ALTER
# CURRENT USER SET PASSWORD`. See docs/decisions/why-env-driven-db-credentials-2026-06-16.md.
NEO4J_PASSWORD=

# PostGIS credentials. docker-compose builds POSTGIS_URI (backend/worker/worker_beat)
# and Martin's DATABASE_URL from these three. POSTGRES_PASSWORD is required
# (fail-closed); user/db keep the "sentinel" default. Applied on FIRST init of the
# pg_data volume only — rotate later with `ALTER ROLE <user> PASSWORD …`.
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=
POSTGRES_DB=sentinel
# POSTGIS_URI is auto-composed by docker-compose from the three vars above; set it
# explicitly here only when running the backend OUTSIDE compose.
POSTGIS_POOL_MIN=1
POSTGIS_POOL_MAX=10

REDIS_URL=redis://redis:6379/0
TITILER_URL=http://titiler:8080

# Internal SAM 3 open-vocabulary segmentation/tracking inference service.
INFERENCE_SAM3_URL=http://inference-sam3:8001


# --- Data paths ------------------------------------------------------------

IMAGERY_PATH=/data/imagery
FMV_PATH=/data/fmv
DATASET_PATH=/data/datasets
# Worldwide Copernicus GLO-30 DEM mosaic. Populated by the `dem-baker` Compose
# profile on a connected host — see docs/deployment/dem-glo30-bake.md. If the
# VRT is missing, /api/analytics/viewshed and /api/analytics/los return 503.
DEM_PATH=/data/dem/glo30.vrt
# Planet-scale routing sidecar. Populated by the `osrm-baker` Compose profile
# — see docs/deployment/osrm-planet-bake.md. If OSRM is unreachable,
# /api/analytics/routes returns 503.
OSRM_URL=http://osrm:5000


# --- Backend API -----------------------------------------------------------

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_BYTES=10737418240


# --- Authentication --------------------------------------------------------

# Bootstrap admin (env-only; cannot be edited from the UI). Use a long random
# password for ADMIN_PASSWORD before exposing the platform.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Signs the session cookie. Replace with `openssl rand -hex 32` output.
SESSION_SECRET=
# Cookie lifetime in hours.
SESSION_TTL_HOURS=12
# Set to 1 in production with HTTPS to mark the session cookie Secure.
FORCE_HTTPS=0

# LDAP is configured at runtime via Admin > Auth tab. These are only used if
# the saved auth_config row is empty (first-boot defaults).
LDAP_DEFAULT_HOST=
LDAP_DEFAULT_PORT=389
LDAP_DEFAULT_BASE_DN=
LDAP_DEFAULT_BIND_DN=


# --- Deployment posture ----------------------------------------------------

# Login-screen banner. 'demo' (default) shows "DEMO BUILD · NOT FOR
# OPERATIONAL USE" — a stock open-source build has no accreditation to imply
# otherwise. Set to 'internal' or 'accredited' for a deployment that does,
# and provide SENTINEL_DEPLOYMENT_LABEL with the site-specific banner text.
SENTINEL_DEPLOYMENT_MODE=demo
SENTINEL_DEPLOYMENT_LABEL=
# Optional admin contact shown on the login screen for LDAP deployments.
SENTINEL_AUTH_SUPPORT_CONTACT=


# --- Ava / LLM classification ---------------------------------------------

OPENAI_API_BASE=http://host.docker.internal:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=google/gemma-4-31b-it
ENABLE_LLM_DETECTION_CLASSIFICATION=true
LLM_DETECTION_BATCH_SIZE=8
LLM_DETECTION_CLASS_TIMEOUT_SECONDS=3


# --- Detection policy ------------------------------------------------------

DETECTION_TAXONOMY_VERSION=open-world-v1
DETECTION_THRESHOLD_PROFILE=defence_precision
GLOBAL_CONFIDENCE_FLOOR=0.35
HIGH_CONFIDENCE_THRESHOLD=0.65
PER_CLASS_CONFIDENCE_OVERRIDES={}

# Reference Embedding DB auto-identify threshold (cosine score in [0,1]).
# Top-1 candidate above this threshold is auto-applied to object_details.
# Read at worker process start — requires `docker compose restart worker` to take effect.
REFERENCE_ID_AUTO_THRESHOLD=0.85


# --- Imagery worker --------------------------------------------------------

INFERENCE_SPEED_PROFILE=recall_review
INFERENCE_CHIP_SIZE=1008
INFERENCE_CHIP_OVERLAP=252
# Optional second-scale (small-object) chip pass — the SAHI-style small-object
# boost. Default 0 disables it and the imagery worker runs only the main pass
# above. Recommended enable value: 504 (half the 1008 main chip), giving small
# targets (TELs, light armour, fuel bowsers) ~2x pixels-per-object once the
# detector upsamples. Both passes share one dedupe index, so cross-scale
# duplicates of the same object are suppressed (NMS/WBF). OVERLAP and MAX_CHIPS
# govern that second pass only; MAX_CHIPS defaults to the speed profile's chip
# cap. Cost: a finer grid is ~4x the chips per unit area (capped by MAX_CHIPS),
# so expect roughly +1 inference pass of GPU time per scene. Now ON by default
# (504 = half the 1008 main chip) for dense-scene small-object recall; this is
# the highest-cost recall knob — set to 0 to opt out on throughput-bound hosts.
# See docs/inference/sahi-equivalence.md,
# docs/decisions/multi-scale-and-full-scene-chip-passes.md, and
# docs/decisions/dense-scene-recall-defaults.md.
INFERENCE_SMALL_OBJECT_CHIP_SIZE=504
INFERENCE_SMALL_OBJECT_OVERLAP=128
# Optional coarse full-scene pass. Default 0 (off). When 1, the worker adds ONE
# downsampled whole-image inference (the full extent read from COG overviews at
# ~chip_size) to catch objects larger than a single chip — runways, piers,
# large facilities — that the sliding-window grid only ever sees fragmented.
# Shares the same dedupe index as the grid passes, so an object seen both whole
# and fragmented is fused/suppressed. Contributes exactly one extra inference.
INFERENCE_FULL_SCENE_PASS=0
# Pad variable-size edge RGB chips to chip_size² so SAM3's torch.compile graph
# (SAM3_COMPILE_IMAGE=1) applies to EVERY chip, not just full-size interior ones
# (~6x faster on edge windows). ON by default; pairs with SAM3_COMPILE_IMAGE.
# See docs/decisions/sam3-compile-and-chip-padding-2026-06-14.md.
INFERENCE_PAD_CHIPS_TO_SIZE=1
# Cross-chip dedupe method for reconciling duplicate detections in chip-overlap
# zones. "nms" (default) keeps the highest-scoring box per cluster; "wbf" fuses
# overlapping boxes (weighted by score). NMS is the default — a DOTA-val eval
# (docs/benchmarks/chip-dedupe-nms-vs-wbf-2026-06-12.md) found WBF gave no recall
# gain and slightly worse precision/F1. WBF_* tune the fuser when DEDUPE_METHOD=wbf.
DEDUPE_METHOD=nms
WBF_IOU_THRESHOLD=0.55
WBF_EXPECTED_MODELS=2
# Cross-tile NMS dedup mode (consumed by fusion.mask_aware_nms in inference-sam3).
# Dense-scene recall defaults: AGNOSTIC=0 keeps suppression per-class (adjacent
# objects labelled differently by SAM3 vs DOTA-OBB aren't cross-dropped); SOFT=1
# decays overlapping detections instead of dropping them (raises recall in ports,
# parking lots). Flip back to AGNOSTIC=1 / SOFT=0 for sparse wide-area imagery if
# precision dips. These live in the configure_host.py generated block on a tuned
# host. See docs/decisions/dense-scene-recall-defaults.md.
SAM3_NMS_AGNOSTIC=0
SAM3_NMS_SOFT=1
# Chip-count caps removed — the worker always runs FULL raster coverage. Coverage
# is governed by INFERENCE_SPEED_PROFILE (recall_review = full, no sub-sampling);
# the old MAX_INFERENCE_CHIPS / INFERENCE_SMALL_OBJECT_MAX_CHIPS knobs no longer exist.
INFERENCE_CHIP_CONCURRENCY=1
INFERENCE_MAX_PENDING_CHIPS=32
# Floor for the adaptive concurrency back-off so it never starves the inference
# GPU-replica pool. Set to your inference GPU/replica count (e.g. 4 on a 4-GPU host).
INFERENCE_MIN_PENDING_CHIPS=4
INFERENCE_CHIP_SPOOL_MAX_BYTES=4194304
INFERENCE_CHIP_TIMEOUT_S=600
# Live (streaming) detections — render detections on the map as each chip is
# detected instead of after the whole pass. 1=on (default). The per-chip WS
# event embeds map-ready features; a chip with more than the cap streams counts
# only (the end-of-pass load still reconciles).
LIVE_DETECTIONS_STREAM=1
LIVE_DETECTIONS_MAX_FEATURES=400
# Remote HTTP(S) imagery ingest is disabled by default for air-gapped runtime.
# Stage files under IMAGERY_PATH/incoming, or explicitly enable and allowlist
# connected-host sources during pre-deployment preparation.
ALLOW_REMOTE_IMAGERY_URLS=0
REMOTE_IMAGERY_ALLOWED_HOSTS=
REMOTE_IMAGERY_MAX_BYTES=10737418240

# --- Raster I/O tuning (GDAL) ----------------------------------------------
# Tuned defaults are also set in code via setdefault() — these lines only
# matter if you want to override. Documented at
# docs/deployment/environment-variables-reference.md.
GDAL_CACHEMAX=1024
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
GDAL_HTTP_MERGE_CONSECUTIVE_RANGES=YES
GDAL_HTTP_MULTIPLEX=YES
GDAL_HTTP_VERSION=2
VSI_CACHE=TRUE
VSI_CACHE_SIZE=5000000
CPL_VSIL_CURL_CACHE_SIZE=200000000
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.tiff,.jp2
GTIFF_VIRTUAL_MEM_IO=YES

# COG conversion (ensure_cog → gdal_translate). ZSTD beats DEFLATE on both
# read and write at similar size; LERC_ZSTD trades a tiny radiometric error
# for another step up in throughput. Set to NONE on hot SSD with capacity.
COG_COMPRESS=ZSTD
COG_BLOCKSIZE=512
COG_PREDICTOR=2

# Model version string stored with detection output.
MODEL_VERSION=sam3-open-vocab


# --- SAM3 inference --------------------------------------------------------

# Required during connected image builds for gated Meta SAM3/SAM3.1 and DINOv3 weights.
HF_TOKEN=

SAM3_DEVICE=auto
# GPU allocation is AUTOMATED by `python scripts/configure_host.py`: it assigns
# the non-reserved GPUs to inference-sam3, writing SAM3_VISIBLE_DEVICES into the
# generated block. To carve out co-tenants (e.g. vLLM), set
# SENTINEL_RESERVED_GPUS below and re-run configure_host — do NOT hand-set
# SAM3_VISIBLE_DEVICES (the generated block overwrites it). Unset → "all".
# SAM3_VISIBLE_DEVICES is generated; leave it to configure_host.
# Operator input: GPUs to keep AWAY from Sentinel (co-tenants like vLLM).
# SENTINEL_RESERVED_GPUS=0,1
SAM3_MODEL_VERSION=sam3-image+sam3.1-video+dinov3-sat-l+terramind+mvrsd
SAM3_IMAGE_MODEL_ID=facebook/sam3
SAM3_USE_MULTIPLEX=1
DINOV3_SAT_MODEL_ID=facebook/dinov3-vitl16-pretrain-sat493m
TERRAMIND_MODEL_ID=terramind_v1_large
SAM3_TEXT_THRESHOLD=0.50
SAM3_BOX_THRESHOLD=0.25
SAM3_CATEGORY_THRESHOLD=0.40
# SegEarth-OV3-inspired distribution-shape gate; see docs/decisions/why-segearth-presence-filter.md
SAM3_PRESENCE_MODE=both
SAM3_PRESENCE_RATIO_FLOOR=1.8
SAM3_PRESENCE_RATIO_EPS=0.05
SAM3_SAR_CONF_CAP=0.85
SAM3_OBB_OPENING_KERNEL_PCT=0.01
SAM3_OBB_MIN_AREA_PX=4
# Cross-detector fusion: wbf (default) | nms (legacy mask-aware NMS). See docs/decisions/why-wbf-over-nms.md
SAM3_FUSION_MODE=wbf
# Per-detector WBF weights override (JSON dict); empty = defaults from fusion.py
SAM3_WBF_WEIGHTS=
SAM3_WBF_IOU=0.55
SAM3_WBF_SKIP_THRESHOLD=0.05
SAM3_DEFAULT_PROMPT_SOURCE=precision
SAM3_PRECISION_DEFAULT_PROMPTS=
SAM3_DEFAULT_PROMPT_PROFILE=
# Prompt cap removed: the full resolved vocabulary runs per /detect (no
# truncation). The old SAM3_MAX_PROMPTS_PER_REQUEST / SAM3_MAX_IMAGE_PROMPTS /
# SAM3_MAX_VIDEO_PROMPTS knobs no longer exist. Per-chip SAM3 decode scales
# linearly with prompt count. See docs/decisions/removed-sam3-prompt-cap-2026-06-14.md.
SAM3_LABEL_FILE=
SAM3_BATCHED_TEXT=1
SAM3_BATCHED_TEXT_CHUNK_SIZE=8
# torch.compile of the SAM3 image+decode graph. ON by default (one-time ~30-40s
# compile on the first /detect after start, then large steady-state speedup with
# ZERO quality change). Pairs with INFERENCE_PAD_CHIPS_TO_SIZE=1. Set 0 if your
# GPU/torch stack can't compile. See docs/decisions/sam3-compile-and-chip-padding-2026-06-14.md.
SAM3_COMPILE_IMAGE=1
SAM3_COMPILE_VIDEO=0
SAM3_WARM_UP_VIDEO=1
SAM3_PRELOAD_MODELS=1
SAM3_EMBED_DETECTIONS=1
SAM3_INSTALL_FAST_DEPS=1

# Per-component model loaders. Disable individual flags if VRAM is tight.
SAM3_LOAD_OPTIONAL_MODELS=1
SAM3_LOAD_DINOV3_SAT=1
# Crops per DINOv3 forward in the batched per-detection embedding path (bounds VRAM).
SAM3_EMBED_BATCH_SIZE=32
# Per-process VRAM ceiling (fraction of each GPU's total). Manual only:
# configure_host.py no longer auto-sets this because live memory.used misfired
# on Sentinel's own replicas. 0 = no cap (dedicated card).
SAM3_GPU_MEMORY_FRACTION=0
SAM3_LOAD_TERRAMIND=1
SAM3_LOAD_DOTA_OBB=1
SAM3_LOAD_YOLOE=1
# YOLOE FMV/specialist inference resolution. Default 896 (was 640) for better
# far/small-target recall; /32-aligned, tunable to 960/1024 (denser, slower) or
# 640 (faster). See docs/decisions/dense-scene-recall-defaults.md.
YOLOE_IMGSZ=896
# MVRSD military-vehicle specialist (fine-tuned yolo11m detect, 5 classes,
# sub-meter ~0.3 m optical RGB). Default-ON: loads with the imagery_rgb profile
# and runs on every RGB /detect like DOTA-OBB, gated by the normal default-True
# _layer_active filter; opt out per request (omit "mvrsd" from a non-empty
# enabled_layers) or set SAM3_LOAD_MVRSD=0 to disable globally. Requires the
# weight baked at build time via MVRSD_WEIGHTS_URL.
# See docs/decisions/why-mvrsd-military-vehicle-specialist.md.
SAM3_LOAD_MVRSD=1
MVRSD_CONF=0.25
# Build-time URL for the MVRSD weight (GitHub release asset). Empty default:
# the orchestrator fills it after upload. Empty = bake step no-ops and the
# runner honour-gates, so existing builds do not break. The compose default
# points at the PRIVATE repo's asset API endpoint, so GITHUB_TOKEN below MUST
# be set for the build-time fetch to authenticate — otherwise the curl 404s,
# the bake silently skips, and /models/mvrsd/ stays empty (layer loads but
# contributes zero candidates).
MVRSD_WEIGHTS_URL=
# Bearer token for the build-time MVRSD weight fetch from the private repo's
# release asset (see MVRSD_WEIGHTS_URL). Read from the build host's environment
# by docker-compose.yml build args. Leave empty only if MVRSD_WEIGHTS_URL is
# empty or points at a public asset.
GITHUB_TOKEN=

# DOTA/remote-sensing detector defaults. yolo11n-obb.pt remains a low-VRAM fallback.
DOTA_OBB_MODEL_ID=yolo26m-obb.pt
EVIDENCE_MAX_ASPECT_RATIO=35
EVIDENCE_MIN_MASK_COMPACTNESS=0.015
EVIDENCE_MIN_VALID_FRACTION=0.20

# Backend worker fallback for SAM3 PCS FMV uploads without user prompts.
FMV_DEFAULT_PROMPTS=vehicle,person,building

# FMV post-inference track consolidation (backend/fmv_tracker.py). Defaults
# are tuned for source-fps frame indexing; override only to retune tracking.
# FMV_TRACKER_COST_WEIGHTS={"iou":1.0,"emb":0.6,"gap":0.3,"class":0.4}
# FMV_TRACK_MIN_IOU=0.30
# FMV_TRACK_MIN_EMB_SIM=0.55
# FMV_TRACK_MAX_FRAME_GAP_SECONDS=2.0
# FMV_TRACK_MATCH_THRESHOLD=1.50
# FMV_TRACK_MERGE_IOU=0.55

# Flip these to 1 once the sam3_models volume is populated.
SAM3_HF_HUB_OFFLINE=0
SAM3_TRANSFORMERS_OFFLINE=0


# --- Frontend ---------------------------------------------------------------

VITE_API_URL=
VITE_TILE_PROXY_URL=/tiles
VITE_TITILER_URL=/tiles
VITE_MARTIN_URL=/maps


# --- Build-time options ----------------------------------------------------

# Run this once per host before docker compose up --build:
#   python scripts/configure_host.py
#
# The command detects nvidia-smi output and writes the generated GPU block to
# .env, populating SAM3_CUDA_VERSION, SAM3_TORCH_INDEX_URL, SAM3_TORCH_VERSION,
# SAM3_TORCHVISION_VERSION, SAM3_TORCH_CUDA_ARCH_LIST, SAM3_GPU_PROFILE,
# SAM3_UBUNTU_VERSION, GPU_MODEL, and NVIDIA runtime visibility keys.
# Do not copy these values between hosts.
