# Gotham GEOINT Platform environment template.
# Copy values into .env and replace placeholder secrets before running outside
# the checked-in docker-compose defaults. Some names are service-local in
# docker-compose.yml, so the same key can intentionally have different values
# for different services.


# --- Core services ---------------------------------------------------------

# Neo4j Bolt endpoint used by the backend and worker.
NEO4J_URI=bolt://neo4j:7687

# Neo4j username used by the backend and worker.
NEO4J_USERNAME=neo4j

# Neo4j password used by the backend and worker.
NEO4J_PASSWORD=password

# Legacy Neo4j password fallback used only when NEO4J_PASSWORD is unset.
NEO4J_AUTH_PASSWORD=password

# Neo4j container bootstrap auth in the form username/password.
NEO4J_AUTH=neo4j/password

# Neo4j plugins loaded by the official container image.
NEO4J_PLUGINS=["apoc"]

# PostGIS connection string used by the backend and worker.
POSTGIS_URI=postgresql://gotham:gotham@postgis:5432/gotham

# Backend/worker psycopg2 pool bounds per process.
POSTGIS_POOL_MIN=1
POSTGIS_POOL_MAX=10

# Postgres container bootstrap user.
POSTGRES_USER=gotham

# Postgres container bootstrap password.
POSTGRES_PASSWORD=gotham

# Postgres container bootstrap database.
POSTGRES_DB=gotham

# Martin vector tile service database connection.
DATABASE_URL=postgresql://gotham:gotham@postgis:5432/gotham

# Redis URL used for Celery, events, and transient backend state.
REDIS_URL=redis://redis:6379/0

# Internal TiTiler URL used by the backend when building COG tile URLs.
TITILER_URL=http://titiler:8080

# Primary YOLO inference service URL used by the backend and worker.
INFERENCE_URL=http://inference:8001

# Grounding DINO open-vocabulary inference service URL used by the worker.
INFERENCE_LAE_DINO_URL=http://inference-lae-dino:8001

# MMRotate DOTA Oriented R-CNN inference service URL used by the worker.
INFERENCE_MMROTATE_URL=http://inference-mmrotate:8001

# LSKNet large selective kernel inference service URL used by the worker.
INFERENCE_LSKNET_URL=http://inference-lsknet:8001
# Internal SAM 2 segmentation inference service
INFERENCE_SAM2_URL=http://inference-sam2:8001


# --- Data paths ------------------------------------------------------------

# Shared imagery mount used for uploaded rasters and COG access.
IMAGERY_PATH=/data/imagery

# Shared FMV mount used for uploaded video and generated HLS output.
FMV_PATH=/data/fmv

# Shared dataset mount used for model training/evaluation uploads.
DATASET_PATH=/data/datasets


# --- Backend API -----------------------------------------------------------

# Comma-separated browser origins allowed by the API CORS helper.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# --- Ava / LLM classification ---------------------------------------------

# OpenAI-compatible chat completions base URL; leave blank to disable LLM chat.
# Host LLM endpoint used by backend/worker containers. Keep this separate from nginx.
# Requires the compose services' host.docker.internal:host-gateway extra_hosts entry.
OPENAI_API_BASE=http://host.docker.internal:8000/v1

# Bearer token for OPENAI_API_BASE; leave blank for unauthenticated local LLMs.
OPENAI_API_KEY=

# Model name sent to the OpenAI-compatible chat completions endpoint.
OPENAI_MODEL=google/gemma-4-31B-it

# Enable LLM enrichment/classification for detections when an LLM is configured.
ENABLE_LLM_DETECTION_CLASSIFICATION=true

# Number of detections sent to the LLM classifier per batch.
LLM_DETECTION_BATCH_SIZE=8

# Timeout in seconds for each LLM detection classification request.
LLM_DETECTION_CLASS_TIMEOUT_SECONDS=3


# --- Detection policy ------------------------------------------------------

# Taxonomy label/version stored with detection policy decisions.
DETECTION_TAXONOMY_VERSION=optical-defense-v1

# Detection policy preset: recall_review, balanced, or high_precision.
DETECTION_THRESHOLD_PROFILE=recall_review

# Optional global confidence floor override; omit to use the selected profile.
# GLOBAL_CONFIDENCE_FLOOR=0.10

# Optional high-confidence threshold override; omit to use the selected profile.
# HIGH_CONFIDENCE_THRESHOLD=0.55

# Comma-separated parent classes that can be emitted as detections.
ENABLED_PARENT_CLASSES=aircraft,ship,vehicle,military_vehicle,storage_tank,bridge,harbor,airfield,building,infrastructure

# Comma-separated parent classes suppressed as distractors.
DISABLED_PARENT_CLASSES=dam,recreation,water,unknown

# JSON map of class-specific confidence overrides, e.g. {"ship":0.22}.
PER_CLASS_CONFIDENCE_OVERRIDES={}


# --- Imagery worker --------------------------------------------------------

# Chip size in pixels for raster inference tiling.
INFERENCE_CHIP_SIZE=1024

# Overlap in pixels between neighboring inference chips.
INFERENCE_CHIP_OVERLAP=256

# Maximum chips per raster; 0 means process all chips.
MAX_INFERENCE_CHIPS=0

# Chip dispatch concurrency to inference providers.
INFERENCE_CHIP_CONCURRENCY=16

# Maximum encoded chips queued in memory/disk spool while inference requests run.
INFERENCE_MAX_PENDING_CHIPS=32

# Encoded chip PNGs larger than this spill from memory to a temp file.
INFERENCE_CHIP_SPOOL_MAX_BYTES=4194304

# Timeout in seconds for each inference provider request.
INFERENCE_CHIP_TIMEOUT_S=120


# --- YOLO inference --------------------------------------------------------

# Explicit model path for the YOLO inference service.
MODEL_PATH=/app/models/geoint_yolov8_obb.pt

# Alternate trained model path checked when MODEL_PATH is absent.
TRAINED_MODEL_PATH=/app/models/geoint_yolov8_obb.pt

# Ultralytics task type; use obb for oriented boxes or detect for boxes.
MODEL_TASK=obb

# Global inference confidence threshold.
CONFIDENCE_THRESHOLD=0.12

# Non-max suppression IoU threshold.
NMS_IOU_THRESHOLD=0.55

# Maximum detections returned per image chip.
MAX_DETECTIONS_PER_CHIP=300

# YOLO runtime selector: auto prefers TensorRT .engine on GPU when present,
# then falls back to the PyTorch .pt checkpoint. Use pytorch to disable TensorRT.
YOLO_RUNTIME=auto

# TensorRT engine generated on the target GPU host.
YOLO_ENGINE_PATH=/app/models/geoint_yolov8_obb.engine

# TensorRT precision for export/runtime. fp16 is the default quality-preserving
# speed path; int8 requires representative calibration data.
YOLO_TRT_PRECISION=fp16

# YOLO inference/export image size.
YOLO_IMGSZ=1024

# YOLO micro-batching for concurrent /detect requests.
YOLO_BATCH_MAX_SIZE=8
YOLO_BATCH_TIMEOUT_MS=10

# Automatically build a TensorRT engine on GPU startup when the engine is
# missing or was exported for a different GPU/runtime. The service tries these
# batch sizes in order and keeps the first one that succeeds.
YOLO_TRT_AUTO_EXPORT=1
YOLO_TRT_EXPORT_BATCHES=8,4,2,1
YOLO_TRT_WORKSPACE=4

# Force a fresh TensorRT export on next startup.
YOLO_TRT_FORCE_REEXPORT=0

# Run one startup warmup inference per loaded YOLO replica.
YOLO_WARMUP=1

# Model version string stored with detection output; the open-vocabulary
# service uses grounding-dino-base in its own service environment.
MODEL_VERSION=geoint-yolov8-obb-optical-defense


# --- Grounding DINO inference ---------------------------------------------

# Grounding DINO model path or Hugging Face model ID.
GROUNDING_DINO_MODEL_ID=/opt/grounding-dino

# Grounding DINO objectness floor used in model post-processing.
GROUNDING_DINO_BOX_THRESHOLD=0.25

# Grounding DINO text-match floor used in model post-processing.
GROUNDING_DINO_TEXT_THRESHOLD=0.25

# Default open-vocabulary prompt profile. official_lae80c uses the official
# 80-class LAE benchmark vocabulary and chunks prompts in custom-entity style.
LAE_PROMPT_PROFILE=official_lae80c

# Number of official classes per open-vocabulary prompt chunk.
LAE_PROMPT_CHUNK_SIZE=20

# Optional newline/JSON vocabulary file for larger local LAE vocabularies.
# LAE_VOCAB_FILE=/app/vocab/custom_lae_classes.txt

# Keep Hugging Face transformers in offline mode at runtime.
TRANSFORMERS_OFFLINE=1

# Keep Hugging Face Hub in offline mode at runtime.
HF_HUB_OFFLINE=1


# --- MMRotate inference ----------------------------------------------------

# Official MMRotate DOTA Oriented R-CNN config and checkpoint.
MMROTATE_CONFIG=/opt/mmrotate/configs/oriented_rcnn/oriented_rcnn_r50_fpn_1x_dota_le90.py
MMROTATE_CHECKPOINT=/models/oriented_rcnn_r50_fpn_1x_dota_le90-6d2b2ce0.pth
MMROTATE_MODEL_DIR=/models

# Checkpoint download fallback when MMROTATE_CHECKPOINT is missing.
MMROTATE_CHECKPOINT_URL=https://download.openmmlab.com/mmrotate/v0.1.0/oriented_rcnn/oriented_rcnn_r50_fpn_1x_dota_le90/oriented_rcnn_r50_fpn_1x_dota_le90-6d2b2ce0.pth

# Global floor used by the MMRotate service before taxonomy thresholds.
MMROTATE_CONFIDENCE_THRESHOLD=0.10

# MMRotate CUDA/PyTorch build args are generated by:
#   python scripts/configure_host.py


# --- LSKNet inference ------------------------------------------------------

# LSKNet model dir where checkpoints are downloaded.
LSKNET_MODEL_DIR=/models

# Official LSKNet DOTA Oriented R-CNN config and checkpoint.
LSKNET_CONFIG=/opt/mmrotate/configs/oriented_rcnn/oriented_rcnn_r50_fpn_1x_dota_le90.py
LSKNET_CHECKPOINT=/models/oriented_rcnn_r50_fpn_1x_dota_le90-6d2b2ce0.pth

# Checkpoint download fallback when LSKNET_CHECKPOINT is missing.
LSKNET_CHECKPOINT_URL=https://download.openmmlab.com/mmrotate/v0.1.0/oriented_rcnn/oriented_rcnn_r50_fpn_1x_dota_le90/oriented_rcnn_r50_fpn_1x_dota_le90-6d2b2ce0.pth

# Global floor used by the LSKNet service before taxonomy thresholds.
LSKNET_CONFIDENCE_THRESHOLD=0.10


# --- Serving and performance ----------------------------------------------

# Device selector for inference: auto, cpu, cuda:0, or comma-separated devices.
DEVICE=auto

# CPU compute threads per worker; auto sizes from available CPUs.
CPU_THREADS=auto

# Uvicorn worker count for inference services.
WEB_CONCURRENCY=1

# Open-vocabulary GPU micro-batch size and max wait.
LAE_BATCH_MAX_SIZE=1
LAE_BATCH_TIMEOUT_MS=0

# Alternate worker-count variable read by serve.py when WEB_CONCURRENCY is unset.
# UVICORN_WORKERS=1

# Host interface for inference serve.py.
HOST=0.0.0.0

# Port for inference serve.py.
PORT=8001

# ASGI app module for inference serve.py.
APP_MODULE=main:app

# OpenMP thread count; normally set automatically from CPU_THREADS.
# OMP_NUM_THREADS=4

# Intel MKL thread count; normally set automatically from CPU_THREADS.
# MKL_NUM_THREADS=4

# TiTiler worker scaling option used by the TiTiler container.
WORKERS_PER_CORE=1


# --- Frontend ---------------------------------------------------------------

# Browser-visible backend API base URL for the Vite frontend.
# Empty means same-origin: http(s)://<server>:3000/api.
VITE_API_URL=

# Browser-visible tile/FMV proxy URL for Leaflet/Cesium resources.
VITE_TILE_PROXY_URL=/tiles

# Browser-visible TiTiler URL reserved for frontend integrations.
VITE_TITILER_URL=/tiles

# Browser-visible Martin vector tile URL reserved for frontend integrations.
VITE_MARTIN_URL=/maps


# --- Build-time options ----------------------------------------------------

# Run this once per host before docker compose up --build:
#   python scripts/configure_host.py
#
# The command detects nvidia-smi output and writes the generated GPU block to
# .env. Do not copy GPU build settings between hosts.
GPU_MODEL=auto

# The generated block includes values like:
# INFERENCE_CUDA_VERSION, INFERENCE_TORCH_INDEX_URL, INFERENCE_TORCH_VERSION,
# INFERENCE_TORCHVISION_VERSION, INFERENCE_GPU_PROFILE, and equivalent
# LAE_DINO_, MMROTATE_, LSKNET_, and SAM2_ values.
