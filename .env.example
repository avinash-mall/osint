# Gotham GEOINT Platform environment template.
# Copy values into .env and replace placeholder secrets before running outside
# the checked-in docker-compose defaults. Some names are service-local in
# docker-compose.yml, so the same key can intentionally have different values
# for different services.


# --- Core services ---------------------------------------------------------

# Neo4j Bolt endpoint used by the backend and worker.
NEO4J_URI=bolt://neo4j:7687

# Neo4j username used by the backend and worker.
NEO4J_USERNAME=neo4j

# Neo4j password used by the backend and worker.
NEO4J_PASSWORD=password

# Legacy Neo4j password fallback used only when NEO4J_PASSWORD is unset.
NEO4J_AUTH_PASSWORD=password

# Neo4j container bootstrap auth in the form username/password.
NEO4J_AUTH=neo4j/password

# Neo4j plugins loaded by the official container image.
NEO4J_PLUGINS=["apoc"]

# PostGIS connection string used by the backend and worker.
POSTGIS_URI=postgresql://gotham:gotham@postgis:5432/gotham

# Postgres container bootstrap user.
POSTGRES_USER=gotham

# Postgres container bootstrap password.
POSTGRES_PASSWORD=gotham

# Postgres container bootstrap database.
POSTGRES_DB=gotham

# Martin vector tile service database connection.
DATABASE_URL=postgresql://gotham:gotham@postgis:5432/gotham

# Redis URL used for Celery, events, and transient backend state.
REDIS_URL=redis://redis:6379/0

# Internal TiTiler URL used by the backend when building COG tile URLs.
TITILER_URL=http://titiler:8080

# Primary YOLO inference service URL used by the backend and worker.
INFERENCE_URL=http://inference:8001

# LAE-DINO open-vocabulary inference service URL used by the worker.
INFERENCE_LAE_DINO_URL=http://inference-lae-dino:8001


# --- Data paths ------------------------------------------------------------

# Shared imagery mount used for uploaded rasters and COG access.
IMAGERY_PATH=/data/imagery

# Shared FMV mount used for uploaded video and generated HLS output.
FMV_PATH=/data/fmv

# Shared dataset mount used for model training/evaluation uploads.
DATASET_PATH=/data/datasets


# --- Backend API -----------------------------------------------------------

# Comma-separated browser origins allowed by the API CORS helper.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# --- Ava / LLM classification ---------------------------------------------

# OpenAI-compatible chat completions base URL; leave blank to disable LLM chat.
OPENAI_API_BASE=

# Bearer token for OPENAI_API_BASE; leave blank for unauthenticated local LLMs.
OPENAI_API_KEY=

# Model name sent to the OpenAI-compatible chat completions endpoint.
OPENAI_MODEL=google/gemma-4-31B-it

# Enable LLM enrichment/classification for detections when an LLM is configured.
ENABLE_LLM_DETECTION_CLASSIFICATION=true

# Number of detections sent to the LLM classifier per batch.
LLM_DETECTION_BATCH_SIZE=8

# Timeout in seconds for each LLM detection classification request.
LLM_DETECTION_CLASS_TIMEOUT_SECONDS=3


# --- Detection policy ------------------------------------------------------

# Taxonomy label/version stored with detection policy decisions.
DETECTION_TAXONOMY_VERSION=optical-defense-v1

# Detection policy preset: recall_review, balanced, or high_precision.
DETECTION_THRESHOLD_PROFILE=recall_review

# Optional global confidence floor override; omit to use the selected profile.
# GLOBAL_CONFIDENCE_FLOOR=0.10

# Optional high-confidence threshold override; omit to use the selected profile.
# HIGH_CONFIDENCE_THRESHOLD=0.55

# Comma-separated parent classes that can be emitted as detections.
ENABLED_PARENT_CLASSES=aircraft,ship,vehicle,military_vehicle,storage_tank,bridge,harbor,airfield,building,infrastructure

# Comma-separated parent classes suppressed as distractors.
DISABLED_PARENT_CLASSES=dam,recreation,water,unknown

# JSON map of class-specific confidence overrides, e.g. {"ship":0.22}.
PER_CLASS_CONFIDENCE_OVERRIDES={}


# --- Imagery worker --------------------------------------------------------

# Chip size in pixels for raster inference tiling.
INFERENCE_CHIP_SIZE=1024

# Overlap in pixels between neighboring inference chips.
INFERENCE_CHIP_OVERLAP=256

# Maximum chips per raster; 0 means process all chips.
MAX_INFERENCE_CHIPS=0


# --- YOLO inference --------------------------------------------------------

# Explicit model path for the YOLO inference service.
MODEL_PATH=/app/models/geoint_yolov8_obb.pt

# Alternate trained model path checked when MODEL_PATH is absent.
TRAINED_MODEL_PATH=/app/models/geoint_yolov8_obb.pt

# Ultralytics task type; use obb for oriented boxes or detect for boxes.
MODEL_TASK=obb

# Global inference confidence threshold.
CONFIDENCE_THRESHOLD=0.12

# Non-max suppression IoU threshold.
NMS_IOU_THRESHOLD=0.55

# Maximum detections returned per image chip.
MAX_DETECTIONS_PER_CHIP=300

# Model version string stored with detection output; LAE-DINO uses
# lae-dino-swint-lae1m in its own service environment.
MODEL_VERSION=geoint-yolov8-obb-optical-defense


# --- LAE-DINO inference ----------------------------------------------------

# LAE-DINO MMDetection config path inside the inference container.
LAE_DINO_CONFIG=/opt/LAE-DINO/mmdetection_lae/configs/lae_dino/lae_dino_swin-t_pretrain_LAE-1M.py

# LAE-DINO checkpoint path inside the inference container.
LAE_DINO_CHECKPOINT=/opt/LAE-DINO/weights/checkpoints/lae_dino_swint_lae1m-28ca3a15.pth

# Local BERT directory used by LAE-DINO for offline text encoding.
LAE_DINO_BERT_PATH=/opt/LAE-DINO/weights/bert-base-uncased

# Default open-vocabulary text prompt used by LAE-DINO.
DEFAULT_TEXT_PROMPT=aircraft . ship . vehicle . military_vehicle . storage_tank . bridge . harbor . airfield . building . infrastructure

# Keep Hugging Face transformers in offline mode at runtime.
TRANSFORMERS_OFFLINE=1

# Keep Hugging Face Hub in offline mode at runtime.
HF_HUB_OFFLINE=1


# --- Serving and performance ----------------------------------------------

# Device selector for inference: auto, cpu, cuda:0, or comma-separated devices.
DEVICE=auto

# CPU compute threads per worker; auto sizes from available CPUs.
CPU_THREADS=auto

# Uvicorn worker count for inference services.
WEB_CONCURRENCY=1

# Alternate worker-count variable read by serve.py when WEB_CONCURRENCY is unset.
# UVICORN_WORKERS=1

# Host interface for inference serve.py.
HOST=0.0.0.0

# Port for inference serve.py.
PORT=8001

# ASGI app module for inference serve.py.
APP_MODULE=main:app

# OpenMP thread count; normally set automatically from CPU_THREADS.
# OMP_NUM_THREADS=4

# Intel MKL thread count; normally set automatically from CPU_THREADS.
# MKL_NUM_THREADS=4

# TiTiler worker scaling option used by the TiTiler container.
WORKERS_PER_CORE=1


# --- Frontend ---------------------------------------------------------------

# Browser-visible backend API base URL for the Vite frontend.
VITE_API_URL=http://localhost:8080

# Browser-visible tile/FMV proxy URL for Leaflet/Cesium resources.
VITE_TILE_PROXY_URL=http://localhost:8090

# Browser-visible TiTiler URL reserved for frontend integrations.
VITE_TITILER_URL=http://localhost:8081

# Browser-visible Martin vector tile URL reserved for frontend integrations.
VITE_MARTIN_URL=http://localhost:3001


# --- Build-time options ----------------------------------------------------

# PyTorch wheel index used when building the YOLO inference image.
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
