# Sentinel environment template.
# Copy values into .env and replace placeholder secrets before running.
# Never commit real tokens or generated secrets.
# --- Core services ---------------------------------------------------------

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

POSTGIS_URI=postgresql://sentinel:sentinel@postgis:5432/sentinel
POSTGIS_POOL_MIN=1
POSTGIS_POOL_MAX=10

REDIS_URL=redis://redis:6379/0
TITILER_URL=http://titiler:8080

# Internal SAM 3 open-vocabulary segmentation/tracking inference service.
INFERENCE_SAM3_URL=http://inference-sam3:8001


# --- Data paths ------------------------------------------------------------

IMAGERY_PATH=/data/imagery
FMV_PATH=/data/fmv
DATASET_PATH=/data/datasets
# Worldwide Copernicus GLO-30 DEM mosaic. Populated by the `dem-baker` Compose
# profile on a connected host — see docs/deployment/dem-glo30-bake.md. If the
# VRT is missing, /api/analytics/viewshed and /api/analytics/los return 503.
DEM_PATH=/data/dem/glo30.vrt
# Planet-scale routing sidecar. Populated by the `osrm-baker` Compose profile
# — see docs/deployment/osrm-planet-bake.md. If OSRM is unreachable,
# /api/analytics/routes returns 503.
OSRM_URL=http://osrm:5000


# --- Backend API -----------------------------------------------------------

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_BYTES=10737418240


# --- Authentication --------------------------------------------------------

# Bootstrap admin (env-only; cannot be edited from the UI). Use a long random
# password for ADMIN_PASSWORD before exposing the platform.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Signs the session cookie. Replace with `openssl rand -hex 32` output.
SESSION_SECRET=
# Cookie lifetime in hours.
SESSION_TTL_HOURS=12
# Set to 1 in production with HTTPS to mark the session cookie Secure.
FORCE_HTTPS=0

# LDAP is configured at runtime via Admin > Auth tab. These are only used if
# the saved auth_config row is empty (first-boot defaults).
LDAP_DEFAULT_HOST=
LDAP_DEFAULT_PORT=389
LDAP_DEFAULT_BASE_DN=
LDAP_DEFAULT_BIND_DN=


# --- Deployment posture ----------------------------------------------------

# Login-screen banner. 'demo' (default) shows "DEMO BUILD · NOT FOR
# OPERATIONAL USE" — a stock open-source build has no accreditation to imply
# otherwise. Set to 'internal' or 'accredited' for a deployment that does,
# and provide SENTINEL_DEPLOYMENT_LABEL with the site-specific banner text.
SENTINEL_DEPLOYMENT_MODE=demo
SENTINEL_DEPLOYMENT_LABEL=
# Optional admin contact shown on the login screen for LDAP deployments.
SENTINEL_AUTH_SUPPORT_CONTACT=


# --- Ava / LLM classification ---------------------------------------------

OPENAI_API_BASE=http://host.docker.internal:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=google/gemma-4-31b-it
ENABLE_LLM_DETECTION_CLASSIFICATION=true
LLM_DETECTION_BATCH_SIZE=8
LLM_DETECTION_CLASS_TIMEOUT_SECONDS=3


# --- Detection policy ------------------------------------------------------

DETECTION_TAXONOMY_VERSION=open-world-v1
DETECTION_THRESHOLD_PROFILE=defence_precision
GLOBAL_CONFIDENCE_FLOOR=0.35
HIGH_CONFIDENCE_THRESHOLD=0.65
PER_CLASS_CONFIDENCE_OVERRIDES={}

# Reference Embedding DB auto-identify threshold (cosine score in [0,1]).
# Top-1 candidate above this threshold is auto-applied to object_details.
# Read at worker process start — requires `docker compose restart worker` to take effect.
REFERENCE_ID_AUTO_THRESHOLD=0.85


# --- Imagery worker --------------------------------------------------------

INFERENCE_SPEED_PROFILE=fast_review
INFERENCE_CHIP_SIZE=1008
INFERENCE_CHIP_OVERLAP=252
MAX_INFERENCE_CHIPS=256
INFERENCE_CHIP_CONCURRENCY=1
INFERENCE_MAX_PENDING_CHIPS=32
# Floor for the adaptive concurrency back-off so it never starves the inference
# GPU-replica pool. Set to your inference GPU/replica count (e.g. 4 on a 4-GPU host).
INFERENCE_MIN_PENDING_CHIPS=4
INFERENCE_CHIP_SPOOL_MAX_BYTES=4194304
INFERENCE_CHIP_TIMEOUT_S=600
# Remote HTTP(S) imagery ingest is disabled by default for air-gapped runtime.
# Stage files under IMAGERY_PATH/incoming, or explicitly enable and allowlist
# connected-host sources during pre-deployment preparation.
ALLOW_REMOTE_IMAGERY_URLS=0
REMOTE_IMAGERY_ALLOWED_HOSTS=
REMOTE_IMAGERY_MAX_BYTES=10737418240

# --- Raster I/O tuning (GDAL) ----------------------------------------------
# Tuned defaults are also set in code via setdefault() — these lines only
# matter if you want to override. Documented at
# docs/deployment/environment-variables-reference.md.
GDAL_CACHEMAX=1024
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
GDAL_HTTP_MERGE_CONSECUTIVE_RANGES=YES
GDAL_HTTP_MULTIPLEX=YES
GDAL_HTTP_VERSION=2
VSI_CACHE=TRUE
VSI_CACHE_SIZE=5000000
CPL_VSIL_CURL_CACHE_SIZE=200000000
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.tiff,.jp2
GTIFF_VIRTUAL_MEM_IO=YES

# COG conversion (ensure_cog → gdal_translate). ZSTD beats DEFLATE on both
# read and write at similar size; LERC_ZSTD trades a tiny radiometric error
# for another step up in throughput. Set to NONE on hot SSD with capacity.
COG_COMPRESS=ZSTD
COG_BLOCKSIZE=512
COG_PREDICTOR=2

# Model version string stored with detection output.
MODEL_VERSION=sam3-open-vocab


# --- SAM3 inference --------------------------------------------------------

# Required during connected image builds for gated Meta SAM3/SAM3.1 and DINOv3 weights.
HF_TOKEN=

SAM3_DEVICE=auto
# Which physical GPUs the inference-sam3 container may use. Unset/missing → all
# GPUs. Set to e.g. "2,3" to dedicate specific cards and leave the rest for a
# co-tenant (e.g. a vLLM server on "0,1"). Selected cards remap to cuda:0..N in
# the container, so SAM3_DEVICE=auto builds one replica per selected card.
# Requires the nvidia docker runtime (see docker-compose.yml inference-sam3).
SAM3_VISIBLE_DEVICES=all
SAM3_MODEL_VERSION=sam3-image+sam3.1-video+dinov3-sat-l+prithvi+terramind
SAM3_IMAGE_MODEL_ID=facebook/sam3
SAM3_USE_MULTIPLEX=1
DINOV3_SAT_MODEL_ID=facebook/dinov3-vitl16-pretrain-sat493m
PRITHVI_BACKBONE_ID=ibm-nasa-geospatial/Prithvi-EO-2.0-600M-TL
TERRAMIND_MODEL_ID=terramind_v1_large
SAM3_TEXT_THRESHOLD=0.50
SAM3_BOX_THRESHOLD=0.25
SAM3_CATEGORY_THRESHOLD=0.40
# SegEarth-OV3-inspired distribution-shape gate; see docs/decisions/why-segearth-presence-filter.md
SAM3_PRESENCE_MODE=both
SAM3_PRESENCE_RATIO_FLOOR=1.8
SAM3_PRESENCE_RATIO_EPS=0.05
SAM3_PRITHVI_OVERLAY_THRESHOLD=0.30
SAM3_SAR_CONF_CAP=0.85
SAM3_OBB_OPENING_KERNEL_PCT=0.01
SAM3_OBB_MIN_AREA_PX=4
# Cross-detector fusion: wbf (default) | nms (legacy mask-aware NMS). See docs/decisions/why-wbf-over-nms.md
SAM3_FUSION_MODE=wbf
# Per-detector WBF weights override (JSON dict); empty = defaults from fusion.py
SAM3_WBF_WEIGHTS=
SAM3_WBF_IOU=0.55
SAM3_WBF_SKIP_THRESHOLD=0.05
SAM3_DEFAULT_PROMPT_SOURCE=precision
SAM3_PRECISION_DEFAULT_PROMPTS=
SAM3_DEFAULT_PROMPT_PROFILE=
SAM3_MAX_PROMPTS_PER_REQUEST=64
SAM3_MAX_IMAGE_PROMPTS=64
SAM3_MAX_VIDEO_PROMPTS=128
SAM3_LABEL_FILE=
SAM3_BATCHED_TEXT=1
SAM3_BATCHED_TEXT_CHUNK_SIZE=8
SAM3_COMPILE_IMAGE=0
SAM3_COMPILE_VIDEO=0
SAM3_WARM_UP_VIDEO=1
SAM3_PRELOAD_MODELS=1
SAM3_EMBED_DETECTIONS=1
SAM3_INSTALL_FAST_DEPS=1

# Per-component model loaders. Disable individual flags if VRAM is tight.
SAM3_LOAD_OPTIONAL_MODELS=1
SAM3_LOAD_DINOV3_SAT=1
# Crops per DINOv3 forward in the batched per-detection embedding path (bounds VRAM).
SAM3_EMBED_BATCH_SIZE=32
# Per-process VRAM ceiling (fraction of each GPU's total). 0 = no cap (dedicated card).
# configure_host.py auto-sets this when another process (e.g. a vLLM server) shares the
# GPUs, so an over-budget allocation OOMs cleanly instead of illegal-accessing the neighbour.
SAM3_GPU_MEMORY_FRACTION=0
SAM3_LOAD_PRITHVI=0
SAM3_LOAD_TERRAMIND=1
SAM3_LOAD_DOTA_OBB=1
# The grounding_dino layer is now backed by LAE-DINO (remote-sensing open-vocab
# detector) running in the separate `inference-lae` service. Enabling it (=1)
# requires bringing that service up: `docker compose --profile lae up --build`.
# Left OFF by default — see docs/inference/lae-dino-sidecar.md.
SAM3_LOAD_GROUNDING_DINO=0
LAE_DINO_URL=http://inference-lae:8010
# LAE-DINO box/text score floors (model-specific; not the old GD weights').
GROUNDING_DINO_THRESHOLD=0.30
GROUNDING_DINO_TEXT_THRESHOLD=0.25
# LAE-DINO is single-GPU. Left unset it co-locates on the same card(s) you gave
# inference-sam3 (SAM3_VISIBLE_DEVICES) — never a co-tenant's GPUs (e.g. vLLM).
# Set this to pin a specific card, e.g. LAE_VISIBLE_DEVICES=3.
# LAE_VISIBLE_DEVICES=
SAM3_LOAD_YOLOE=1

# DOTA/remote-sensing detector defaults. yolo11n-obb.pt remains a low-VRAM fallback.
DOTA_OBB_MODEL_ID=yolo26m-obb.pt
EVIDENCE_MAX_ASPECT_RATIO=35
EVIDENCE_MIN_MASK_COMPACTNESS=0.015
EVIDENCE_MIN_VALID_FRACTION=0.20

# Backend worker fallback for SAM3 PCS FMV uploads without user prompts.
FMV_DEFAULT_PROMPTS=vehicle,person,building

# FMV post-inference track consolidation (backend/fmv_tracker.py). Defaults
# are tuned for source-fps frame indexing; override only to retune tracking.
# FMV_TRACKER_COST_WEIGHTS={"iou":1.0,"emb":0.6,"gap":0.3,"class":0.4}
# FMV_TRACK_MIN_IOU=0.30
# FMV_TRACK_MIN_EMB_SIM=0.55
# FMV_TRACK_MAX_FRAME_GAP_SECONDS=2.0
# FMV_TRACK_MATCH_THRESHOLD=1.50
# FMV_TRACK_MERGE_IOU=0.55

# Flip these to 1 once the sam3_models volume is populated.
SAM3_HF_HUB_OFFLINE=0
SAM3_TRANSFORMERS_OFFLINE=0


# --- Frontend ---------------------------------------------------------------

VITE_API_URL=
VITE_TILE_PROXY_URL=/tiles
VITE_TITILER_URL=/tiles
VITE_MARTIN_URL=/maps


# --- Build-time options ----------------------------------------------------

# Run this once per host before docker compose up --build:
#   python scripts/configure_host.py
#
# The command detects nvidia-smi output and writes the generated GPU block to
# .env, populating SAM3_CUDA_VERSION, SAM3_TORCH_INDEX_URL, SAM3_TORCH_VERSION,
# SAM3_TORCHVISION_VERSION, SAM3_TORCH_CUDA_ARCH_LIST, SAM3_GPU_PROFILE,
# SAM3_UBUNTU_VERSION, GPU_MODEL, and NVIDIA runtime visibility keys.
# Do not copy these values between hosts.
