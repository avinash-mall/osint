# Worldwide Copernicus GLO-30 DEM mosaic (~150 GB) and planet OSRM dataset
# (~150-200 GB). Populated on first `docker compose up` from the dem-assets
# and osrm-assets init containers; ships as plain folders for air-gap
# transfer. Track only the .gitkeep so the dirs exist for bind-mounting.
/assets/dem/*
!/assets/dem/.gitkeep
/assets/osrm/*
!/assets/osrm/.gitkeep

# Operator-provided drop-in for restricted-access reference corpora.
# Tracked: only the .gitkeep README; ignore everything else (tarballs,
# extracted trees, manifests the operator generated).
/reference-corpora-input/*
!/reference-corpora-input/.gitkeep

# Offline-build model cache (~16 GB): a previously-baked /models tree staged via
# `docker cp <inference-container>:/models/. ./model-cache/` so the inference
# image can rebuild on an air-gapped / cache-pruned host without re-downloading
# from HF (compose additional_contexts → Dockerfile.gpu seed step). Track only
# the .gitkeep so the build-context path exists on a fresh clone.
/model-cache/*
!/model-cache/.gitkeep

# FAIR1M-OBB weights are operator-baked, not source-controlled (~80 MB).
# Drop-in lives at assets/static/inference-weights/fair1m/. See
# docs/operations/fair1m-bake.md.
/assets/static/inference-weights/fair1m/*.pt
*_logs.txt
*_output.txt
build_*.txt
*.log
/tmp/
/temp/

# Celery Beat schedule DB — runtime state rewritten on every tick by the
# worker_beat container; not source. Tracked by mistake; untracked here.
backend/celerybeat-schedule

# Docker bind-mount point: compose mounts `./backend/detection_policy.py` onto
# `/app/detection_policy.py`, and `/app` is the `inference-sam3/` bind mount — so
# docker recreates this host-side mount point (root-owned, 0-byte) on every
# inference-sam3 start. It is NOT source; the real module is backend/detection_policy.py.
inference-sam3/detection_policy.py

# Per-chip /detect response cache from scripts/eval_chip_dedupe.py (runtime artifact)
bench/chip_dedupe_cache/
